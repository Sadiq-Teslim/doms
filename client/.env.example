# Frontend environment variables (Vite).
# Copy to .env for local overrides, or set in your host's dashboard for production.

# Base URL of the deployed DOMS backend API (must include the /api suffix).
# Leave UNSET for local dev — Vite proxies /api to http://localhost:4000 automatically.
# Example:
# VITE_API_URL=https://your-doms-api.onrender.com/api
